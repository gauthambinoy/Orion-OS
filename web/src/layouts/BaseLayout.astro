---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Orion OS — an AI-first Linux desktop.' } =
  Astro.props;
const year = new Date().getUTCFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header>
      <nav aria-label="Primary">
        <a class="brand" href="/">Orion OS</a>
        <ul>
          <li><a href="/devlog">Devlog</a></li>
          <li>
            <a href="https://github.com/gauthambinoy/Orion-OS" rel="noopener">
              GitHub
            </a>
          </li>
        </ul>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer>
      <p>
        © {year} Orion OS contributors · GPL-3.0-or-later · No telemetry,
        ever.
      </p>
    </footer>
    <style is:global>
      :root {
        --bg: #ffffff;
        --fg: #14181f;
        --muted: #5a6473;
        --accent: #2f5dff;
        --border: #e4e7ec;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0d1117;
          --fg: #e6edf3;
          --muted: #8b949e;
          --accent: #6f9bff;
          --border: #1f2630;
        }
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font: 16px/1.6 system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover,
      a:focus {
        text-decoration: underline;
      }
      .skip {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip:focus {
        left: 1rem;
        top: 1rem;
        background: var(--bg);
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--border);
      }
      header,
      footer {
        border-bottom: 1px solid var(--border);
      }
      footer {
        border: 0;
        border-top: 1px solid var(--border);
        margin-top: 4rem;
      }
      header nav,
      main,
      footer p {
        max-width: 760px;
        margin: 0 auto;
        padding: 1rem 1.25rem;
      }
      header nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      header .brand {
        font-weight: 700;
        color: var(--fg);
      }
      header ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 1.25rem;
      }
      main {
        padding-top: 2.5rem;
        padding-bottom: 2.5rem;
      }
      h1 {
        font-size: 2rem;
        line-height: 1.2;
        margin-top: 0;
      }
      h2 {
        margin-top: 2.5rem;
      }
      footer p {
        color: var(--muted);
        font-size: 0.9rem;
      }
      time {
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }
      article + article {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
      }
      code {
        background: var(--border);
        padding: 0.1em 0.3em;
        border-radius: 3px;
        font-size: 0.95em;
      }
    </style>
  </body>
</html>
