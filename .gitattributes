# Orion OS — .gitattributes
# Normalise line endings, mark generated files, and keep binary blobs
# from being diffed.

# ---- Default: detect text vs binary, normalise text to LF ----
* text=auto eol=lf

# ---- Explicit text formats (always LF, no auto-conversion surprises) ----
*.md       text eol=lf
*.toml     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.rs       text eol=lf
*.qml      text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.service  text eol=lf
*.target   text eol=lf
*.timer    text eol=lf
*.socket   text eol=lf
*.conf     text eol=lf
Containerfile text eol=lf
Dockerfile text eol=lf
justfile   text eol=lf
Makefile   text eol=lf

# ---- Shell scripts must keep LF ----
*.bash     text eol=lf

# ---- Windows-only files (none expected, but be explicit) ----
*.bat      text eol=crlf
*.ps1      text eol=crlf

# ---- Binary assets — never diff, never normalise ----
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.icns     binary
*.svg      text eol=lf
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.mp3      binary
*.ogg      binary
*.wav      binary
*.flac     binary
*.mp4      binary
*.webm     binary
*.zip      binary
*.tar      binary
*.tar.gz   binary
*.tar.zst  binary
*.qcow2    binary
*.img      binary
*.iso      binary
*.raw      binary
*.gguf     binary
*.bin      binary
*.safetensors binary

# ---- Lockfiles: keep them, but mark them as generated for nicer diffs ----
Cargo.lock          linguist-generated
package-lock.json   linguist-generated
pnpm-lock.yaml      linguist-generated
yarn.lock           linguist-generated

# ---- Vendored / generated docs should not skew language stats ----
docs/api/**         linguist-generated
